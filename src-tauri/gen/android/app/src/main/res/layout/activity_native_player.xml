<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false" />

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/header_gradient">

            <View
                android:id="@+id/status_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="12dp"
                android:background="@android:color/darker_gray" />

            <TextView
                android:id="@+id/channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/state_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginStart="12dp"
                android:padding="6dp"
                android:background="#33FFFFFF"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:id="@+id/epg_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="#33000000"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="20dp"
        android:background="@drawable/controls_gradient">

        <Button
            android:id="@+id/seek_backward_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="⏪"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/control_button"
            android:layout_marginEnd="12dp"
            android:stateListAnimator="@null"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:contentDescription="Seek backward 10 seconds"
            android:nextFocusRight="@+id/play_pause_button"
            android:nextFocusUp="@+id/stop_button"
            android:nextFocusDown="@+id/stop_button" />

        <Button
            android:id="@+id/play_pause_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="▶"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/control_button_primary"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:stateListAnimator="@null"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:contentDescription="Play or pause"
            android:nextFocusLeft="@+id/seek_backward_button"
            android:nextFocusRight="@+id/seek_forward_button"
            android:nextFocusUp="@+id/stop_button"
            android:nextFocusDown="@+id/stop_button" />

        <Button
            android:id="@+id/seek_forward_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="⏩"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/control_button"
            android:layout_marginStart="12dp"
            android:stateListAnimator="@null"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:contentDescription="Seek forward 10 seconds"
            android:nextFocusLeft="@+id/play_pause_button"
            android:nextFocusRight="@+id/stop_button"
            android:nextFocusUp="@+id/stop_button"
            android:nextFocusDown="@+id/stop_button" />

        <Button
            android:id="@+id/stop_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="⏹"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/control_button_danger"
            android:layout_marginStart="16dp"
            android:stateListAnimator="@null"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:contentDescription="Stop playback"
            android:nextFocusLeft="@+id/seek_forward_button"
            android:nextFocusRight="@+id/seek_backward_button"
            android:nextFocusUp="@+id/seek_backward_button"
            android:nextFocusDown="@+id/seek_backward_button" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
