<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Główny PlayerView -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:show_buffering="when_playing"
        app:resize_mode="fit" />

    <!-- Top Gradient + Info -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/top_player_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Status Indicator -->
            <View
                android:id="@+id/status_indicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/live_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Channel Name"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/live_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="#FF5252"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/live_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/epg_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading current program..."
            android:textColor="#B0B0B0"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Bottom Controls - Nowoczesny styl -->
    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_player_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp"
        android:paddingTop="16dp">

        <!-- SeekBar z czasem -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <androidx.appcompat.widget.AppCompatSeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:thumbTint="#FFFFFF"
                android:progressTint="#2196F3"
                android:progressBackgroundTint="#40FFFFFF" />

            <TextView
                android:id="@+id/duration_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-00:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Przyciski kontrolne -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/seek_backward_button"
                style="@style/PlayerControlButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:icon="@drawable/ic_replay_10"
                app:iconSize="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/play_pause_button"
                style="@style/PlayerControlButton.Primary"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:icon="@drawable/ic_play_arrow"
                app:iconSize="36dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/seek_forward_button"
                style="@style/PlayerControlButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:icon="@drawable/ic_forward_10"
                app:iconSize="28dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Centralny loading -->
    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

</FrameLayout>
