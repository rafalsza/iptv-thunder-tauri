{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Capabilities for Android and iOS",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "opener:default",
    "store:default",
    "store:allow-load",
    "shell:default",
    "http:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta",
    "fs:scope-appdata-recursive",
    "core:path:default",
    "process:default"
  ]
}
