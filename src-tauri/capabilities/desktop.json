{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop",
  "description": "Capabilities for desktop platforms",
  "windows": ["main"],
  "platforms": ["linux", "macOS", "windows"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "opener:default",
    "store:default",
    "store:allow-load",
    "shell:default",
    "http:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta",
    "fs:scope-appdata-recursive",
    "core:path:default",
    "process:default",
    "stronghold:default",
    "libmpv:default",
    "libmpv:allow-init",
    "libmpv:allow-command",
    "libmpv:allow-destroy",
    "libmpv:allow-get-property",
    "libmpv:allow-set-property"
  ]
}
