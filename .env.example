# IPTV Thunder Environment Configuration
# Copy this file to .env and fill in your values

# Development mode
VITE_DEV_MODE=true

# API Configuration (optional - for custom endpoints)
# VITE_API_BASE_URL=http://localhost:8080

# Debug logging (true/false)
VITE_DEBUG=false

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CRASH_REPORTING=false

# Android TV specific
# Used during Android build process
ANDROID_HOME=/path/to/android/sdk
NDK_HOME=/path/to/android/ndk
