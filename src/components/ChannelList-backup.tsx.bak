import React, { useState, useEffect, useMemo } from 'react';
import { useQuery } from '@tanstack/react-query';
import { motion } from 'framer-motion';
import { Tv, Wifi, WifiOff, Loader2, Film, Clapperboard, MonitorPlay, Search, Heart, ChevronDown } from 'lucide-react';
import { StalkerAccount, StalkerChannel, StalkerVOD, StalkerClient } from '@/lib/stalkerAPI_new';
import { Button } from '@/components/ui/button';
import { Card, CardContent } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { mpvPlayer } from '@/lib/mpvPlayer';
import { Player } from './Player';

interface ChannelListProps {
  activeAccount: StalkerAccount;
}

type ContentType = 'tv' | 'movies' | 'series';

export const ChannelList: React.FC<ChannelListProps> = ({ activeAccount }) => {
  const [selectedGenre, setSelectedGenre] = useState<string>('*');
  const [selectedVodGenre, setSelectedVodGenre] = useState<string>('*');
  const [searchQuery, setSearchQuery] = useState<string>('');
  const [showFavoritesOnly, setShowFavoritesOnly] = useState<boolean>(false);
  const [isPlaying, setIsPlaying] = useState<string | null>(null);
  const [activeTab, setActiveTab] = useState<ContentType>('tv');
  const [currentStream, setCurrentStream] = useState<{url: string, name: string} | null>(null);

  // Infinite scroll state
  const [channelsPage, setChannelsPage] = useState(1);
  const [allChannels, setAllChannels] = useState<StalkerChannel[]>([]);
  const [hasMoreChannels, setHasMoreChannels] = useState(false);
  const [isLoadingMore, setIsLoadingMore] = useState(false);

  // Ulubione - wczytaj z localStorage
  const [favoriteGenres, setFavoriteGenres] = useState<string[]>([]);
  const [favoriteChannels, setFavoriteChannels] = useState<string[]>([]);
  const [favoriteMovies, setFavoriteMovies] = useState<number[]>([]);
  const [favoriteSeries, setFavoriteSeries] = useState<number[]>([]);

  // Wczytaj ulubione z localStorage przy starcie
  useEffect(() => {
    const loadFavorites = () => {
      const storedGenres = localStorage.getItem(`fav-genres-${activeAccount.id}`);
      const storedChannels = localStorage.getItem(`fav-channels-${activeAccount.id}`);
      const storedMovies = localStorage.getItem(`fav-movies-${activeAccount.id}`);
      const storedSeries = localStorage.getItem(`fav-series-${activeAccount.id}`);
      
      if (storedGenres) setFavoriteGenres(JSON.parse(storedGenres));
      if (storedChannels) setFavoriteChannels(JSON.parse(storedChannels));
      if (storedMovies) setFavoriteMovies(JSON.parse(storedMovies));
      if (storedSeries) setFavoriteSeries(JSON.parse(storedSeries));
    };
    loadFavorites();
  }, [activeAccount.id]);

  // Funkcje do zarzĂ"dzania ulubionymi
  const toggleFavoriteGenre = (genreId: string) => {
    const newFavorites = favoriteGenres.includes(genreId)
      ? favoriteGenres.filter(id => id !== genreId)
      : [...favoriteGenres, genreId];
    setFavoriteGenres(newFavorites);
    localStorage.setItem(`fav-genres-${activeAccount.id}`, JSON.stringify(newFavorites));
  };

  const toggleFavoriteChannel = (channelId: string) => {
    const newFavorites = favoriteChannels.includes(channelId)
      ? favoriteChannels.filter(id => id !== channelId)
      : [...favoriteChannels, channelId];
    setFavoriteChannels(newFavorites);
    localStorage.setItem(`fav-channels-${activeAccount.id}`, JSON.stringify(newFavorites));
  };

  const toggleFavoriteMovie = (movieId: number) => {
    const newFavorites = favoriteMovies.includes(movieId)
      ? favoriteMovies.filter(id => id !== movieId)
      : [...favoriteMovies, movieId];
    setFavoriteMovies(newFavorites);
    localStorage.setItem(`fav-movies-${activeAccount.id}`, JSON.stringify(newFavorites));
  };

  const toggleFavoriteSeries = (seriesId: number) => {
    const newFavorites = favoriteSeries.includes(seriesId)
      ? favoriteSeries.filter(id => id !== seriesId)
      : [...favoriteSeries, seriesId];
    setFavoriteSeries(newFavorites);
    localStorage.setItem(`fav-series-${activeAccount.id}`, JSON.stringify(newFavorites));
  };

  // Stworzenie instancji klienta
  const client = React.useMemo(() => new StalkerClient(activeAccount), [activeAccount]);

  // Pobieranie kategorii
  const { data: genres = [], isLoading: genresLoading } = useQuery({
    queryKey: ['genres', activeAccount.id],
    queryFn: () => client.getGenres(),
    enabled: !!activeAccount.token,
  });

  // Reset channels when genre changes
  useEffect(() => {
    setChannelsPage(1);
    setAllChannels([]);
    setHasMoreChannels(false);
  }, [selectedGenre, activeAccount.id]);

  // Pobieranie kanałów z infinite scroll
  const { data: initialChannels = [], isLoading: channelsLoading } = useQuery({
    queryKey: ['channels', activeAccount.id, selectedGenre, channelsPage],
    queryFn: async () => {
      // Dla WSZYSTKICH kategorii pobieramy wszystkie kanały naraz
      const allChannels = await client.getAllChannels();
      setAllChannels(allChannels);
      setHasMoreChannels(false);
      return allChannels;
    },
    enabled: !!activeAccount.token && activeTab === 'tv',
  });

  // Oddzielne query dla getAllChannels aby uniknąć cache'owania problemów
  const { data: allChannelsData = [], isLoading: allChannelsLoading } = useQuery({
    queryKey: ['all-channels', activeAccount.id],
    queryFn: () => client.getAllChannels(),
    enabled: !!activeAccount.token && activeTab === 'tv' && selectedGenre === '*',
  });

  // Pobieranie VOD - filmy
  const { data: movies = [], isLoading: moviesLoading } = useQuery({
    queryKey: ['movies', activeAccount.id, selectedVodGenre],
    queryFn: () => client.getVODList(1, selectedVodGenre === '*' ? undefined : selectedVodGenre),
    enabled: !!activeAccount.token && activeTab === 'movies',
  });

  // Pobieranie VOD - seriale
  const { data: series = [], isLoading: seriesLoading } = useQuery({
    queryKey: ['series', activeAccount.id, selectedVodGenre],
    queryFn: () => client.getVODList(1, selectedVodGenre === '*' ? undefined : selectedVodGenre),
    enabled: !!activeAccount.token && activeTab === 'series',
  });

  // Funkcja do Äą'adowania kolejnych stron
  const loadMoreChannels = () => {
    if (!isLoadingMore && hasMoreChannels) {
      setIsLoadingMore(true);
      setChannelsPage(prev => prev + 1);
    }
  };

  // Odtwarzanie kanału
  const handleChannelClick = async (channel: StalkerChannel) => {
    if (isPlaying) return;

    try {
      setIsPlaying(channel.id);
      const streamUrl = await client.getStreamUrl(channel.cmd);
      
      // Otwórz wbudowany player
      setCurrentStream({ url: streamUrl, name: channel.name });
      
      console.log('Started playing:', channel.name);
    } catch (error) {
      console.error('Error playing channel:', error);
    } finally {
      setIsPlaying(null);
    }
  };

  // Odtwarzanie VOD
  const handleVodClick = async (vod: StalkerVOD) => {
    if (isPlaying) return;

    try {
      setIsPlaying(vod.id.toString());
      const streamUrl = await client.getVODUrl(vod.cmd);
      
      // Otwórz wbudowany player
      setCurrentStream({ url: streamUrl, name: vod.name });
      
      console.log('Started playing VOD:', vod.name);
    } catch (error) {
      console.error('Error playing VOD:', error);
    } finally {
      setIsPlaying(null);
    }
  };

  // Filtrowanie gatunkÄ'Ĺ'w (kategorii) na podstawie wyszukiwania i ulubionych
  const filteredGenres = genres.filter(genre => {
    const matchesSearch = genre.title.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesFavorites = !showFavoritesOnly || favoriteGenres.includes(genre.id);
    return matchesSearch && matchesFavorites;
  });

  // Filtrowanie kanałów - uwzględnij tryb ulubionych
  const filteredChannels = useMemo(() => {
    const channelsToFilter = selectedGenre === '*' ? allChannelsData : initialChannels;
    const result = channelsToFilter.filter(channel => {
      const matchesSearch = channel.name.toLowerCase().includes(searchQuery.toLowerCase());
      // W trybie ulubionych: pokazuj kanały z ulubionej kategorii LUB ulubione kanały
      const matchesFavorites = !showFavoritesOnly || 
                              favoriteGenres.includes(selectedGenre) || 
                              favoriteChannels.includes(channel.id);
      const matchesGenre = selectedGenre === '*' || channel.tv_genre_id === selectedGenre;
      return matchesSearch && matchesFavorites && matchesGenre;
    });
    
    console.log('🔍 Channel filtering debug:', {
      totalChannels: channelsToFilter.length,
      searchQuery,
      showFavoritesOnly,
      selectedGenre,
      favoriteChannels: favoriteChannels.length,
      filteredChannels: result.length,
      hasMoreChannels,
      currentPage: channelsPage
    });
    
    return result;
  }, [allChannelsData, initialChannels, searchQuery, showFavoritesOnly, selectedGenre, favoriteChannels]);
  const filteredMovies = movies.filter(m => {
    const matchesSearch = !m.series && m.name.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesFavorites = !showFavoritesOnly || favoriteMovies.includes(m.id);
    return matchesSearch && matchesFavorites;
  });
  const filteredSeries = series.filter(s => {
    const matchesSearch = s.series && s.name.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesFavorites = !showFavoritesOnly || favoriteSeries.includes(s.id);
    return matchesSearch && matchesFavorites;
  });

  const isLoading = genresLoading || 
    (activeTab === 'tv' && channelsLoading) || 
    (activeTab === 'movies' && moviesLoading) || 
    (activeTab === 'series' && seriesLoading);

  if (genresLoading) {
    return (
      <div className="flex items-center justify-center h-64">
        <Loader2 className="w-8 h-8 animate-spin" />
        <span className="ml-2">Loading categories...</span>
      </div>
    );
  }

  return (
    <div className="flex h-full">
      {/* Sidebar z kategoriami - pokazujemy dla TV, filmy/seriale majĂ" osobne*/}
      <div className="w-72 border-r border-border bg-background overflow-y-auto">
        <div className="p-4 bg-background min-h-full">
          <h2 className="text-lg font-semibold mb-4 flex items-center gap-2">
            <Tv className="w-5 h-5" />
            Categories
          </h2>
          <div className="mb-4">
            <div className="relative">
              <Search className="absolute left-2.5 top-2.5 w-4 h-4 text-muted-foreground" />
              <input
                type="text"
                placeholder="Szukaj kategorii..."
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                className="w-full pl-9 pr-3 py-2 text-sm bg-background border border-border rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              />
            </div>
          </div>
          <div className="space-y-1">
            {filteredGenres.map((genre) => (
              <div key={genre.id} className="flex items-center gap-1">
                <Button
                  variant={
                    (activeTab === 'tv' && selectedGenre === genre.id) ||
                    ((activeTab === 'movies' || activeTab === 'series') && selectedVodGenre === genre.id)
                      ? 'default'
                      : 'ghost'
                  }
                  className="flex-1 justify-start"
                  onClick={() => {
                    if (activeTab === 'tv') {
                      setSelectedGenre(genre.id);
                    } else {
                      setSelectedVodGenre(genre.id);
                    }
                  }}
                >
                  {genre.title}
                </Button>
                <Button
                  variant="ghost"
                  size="sm"
                  className="px-2"
                  onClick={(e) => {
                    e.stopPropagation();
                    toggleFavoriteGenre(genre.id);
                  }}
                >
                  <Heart className={`w-4 h-4 ${favoriteGenres.includes(genre.id) ? 'fill-red-500 text-red-500' : 'text-muted-foreground'}`} />
                </Button>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* GÄą'Ä'Ĺ'wna zawartoÄą>Ă"â"Ľ z zakÄą'adkami */}
      <div className="flex-1 overflow-auto">
        <div className="h-full flex flex-col">
          {/* NagÄą'Ä'Ĺ'wek z zakÄą'adkami */}
          <div className="px-6 pt-6 pb-2">
            <div className="flex gap-2 max-w-lg">
              <Button
                variant={activeTab === 'tv' ? 'default' : 'outline'}
                className="flex-1 flex items-center gap-2"
                onClick={() => setActiveTab('tv')}
              >
                <MonitorPlay className="w-4 h-4" />
                Kanały TV
              </Button>
              <Button
                variant={activeTab === 'movies' ? 'default' : 'outline'}
                className="flex-1 flex items-center gap-2"
                onClick={() => setActiveTab('movies')}
              >
                <Film className="w-4 h-4" />
                Filmy
              </Button>
              <Button
                variant={activeTab === 'series' ? 'default' : 'outline'}
                className="flex-1 flex items-center gap-2"
                onClick={() => setActiveTab('series')}
              >
                <Clapperboard className="w-4 h-4" />
                Seriale
              </Button>
              <Button
                variant={showFavoritesOnly ? 'default' : 'outline'}
                className="flex items-center gap-2 px-3"
                onClick={() => setShowFavoritesOnly(!showFavoritesOnly)}
              >
                <Heart className={`w-4 h-4 ${showFavoritesOnly ? 'fill-current' : ''}`} />
              </Button>
            </div>
          </div>

          {/* Zawartość - Kanały TV */}
          {activeTab === 'tv' && (
            <div className="flex-1 overflow-auto">
              <div className="p-6">
                <div className="mb-6">
                  <h1 className="text-2xl font-bold">
                    {showFavoritesOnly ? 'Ulubione kanały' : (genres.find(g => g.id === selectedGenre)?.title || 'All Channels')}
                  </h1>
                  <p className="text-muted-foreground">
                    {filteredChannels.length} channels available
                  </p>
                </div>

                {channelsLoading ? (
                  <div className="flex items-center justify-center h-64">
                    <Loader2 className="w-8 h-8 animate-spin" />
                    <span className="ml-2">Loading channels...</span>
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                ) : filteredChannels.length === 0 ? (
                  <div className="text-center py-12">
                    <WifiOff className="w-12 h-12 mx-auto mb-4 text-muted-foreground" />
                    <h3 className="text-lg font-medium mb-2">No channels found</h3>
                    <p className="text-muted-foreground">
                      Try selecting a different category or check your connection.
                    </p>
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                ) : (
                  <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-4">
                    {filteredChannels.map((channel) => (
                      <motion.div
                        key={channel.id}
                        whileHover={{ scale: 1.05 }}
                        whileTap={{ scale: 0.95 }}
                        className="cursor-pointer"
                        onClick={() => handleChannelClick(channel)}
                      >
                        <Card className="overflow-hidden hover:shadow-lg transition-shadow">
                          <div className="aspect-video bg-muted flex items-center justify-center p-2">
                            {channel.logo ? (
                              <img
                                src={channel.logo}
                                alt={channel.name}
                                className="w-full h-full max-w-[120px] max-h-[60px] object-contain"
                                onError={(e) => {
                                  e.currentTarget.style.display = 'none';
                                }}
                              />
                            ) : (
                              <Tv className="w-8 h-8 text-muted-foreground" />
                            )}
                          </div>
                          <CardContent className="p-3">
                            <div className="space-y-2">
                              <div className="flex items-center justify-between">
                                <span className="text-sm font-medium truncate">
                                  {channel.name}
                                </span>
                                <div className="flex items-center gap-1">
                                  <button
                                    onClick={(e) => {
                                      e.stopPropagation();
                                      toggleFavoriteChannel(channel.id);
                                    }}
                                    className="p-1 hover:bg-muted rounded"
                                  >
                                    <Heart className={`w-3 h-3 ${favoriteChannels.includes(channel.id) ? 'fill-red-500 text-red-500' : 'text-muted-foreground'}`} />
                                  </button>
                                </div>
                              </div>
                              {isPlaying === channel.id && (
                                <div className="flex items-center gap-2 text-green-500">
                                  <Loader2 className="w-3 h-3 animate-spin" />
                                  <span className="text-xs">Playing...</span>
                                </div>
                              )}
                            </div>
                          </CardContent>
                        </Card>
                      </motion.div>
                    ))}
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                )}
              </div>
            </div>
          )}

          {/* ZawartoÄą>Ă"â"Ľ - Filmy */}
          {activeTab === 'movies' && (
            <div className="flex-1 overflow-auto">
              <div className="p-6">
                <div className="mb-6">
                  <h1 className="text-2xl font-bold">Filmy</h1>
                  <p className="text-muted-foreground">
                    {filteredMovies.length} movies available
                  </p>
                </div>

                {moviesLoading ? (
                  <div className="flex items-center justify-center h-64">
                    <Loader2 className="w-8 h-8 animate-spin" />
                    <span className="ml-2">Loading movies...</span>
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                ) : filteredMovies.length === 0 ? (
                  <div className="text-center py-12">
                    <WifiOff className="w-12 h-12 mx-auto mb-4 text-muted-foreground" />
                    <h3 className="text-lg font-medium mb-2">No movies found</h3>
                    <p className="text-muted-foreground">
                      Try selecting a different category or check your connection.
                    </p>
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                ) : (
                  <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-4">
                    {filteredMovies.map((movie) => (
                      <motion.div
                        key={movie.id}
                        whileHover={{ scale: 1.05 }}
                        whileTap={{ scale: 0.95 }}
                        className="cursor-pointer"
                        onClick={() => handleVodClick(movie)}
                      >
                        <Card className="overflow-hidden hover:shadow-lg transition-shadow">
                          <div className="aspect-[2/3] bg-muted flex items-center justify-center">
                            {movie.poster ? (
                              <img
                                src={movie.poster}
                                alt={movie.name}
                                className="w-full h-full object-cover"
                                onError={(e) => {
                                  e.currentTarget.style.display = 'none';
                                }}
                              />
                            ) : (
                              <Film className="w-12 h-12 text-muted-foreground" />
                            )}
                          </div>
                          <CardContent className="p-3">
                            <div className="space-y-2">
                              <div className="flex items-center justify-between">
                                <span className="text-sm font-medium truncate">
                                  {movie.name}
                                </span>
                                <div className="flex items-center gap-1">
                                  <button
                                    onClick={(e) => {
                                      e.stopPropagation();
                                      toggleFavoriteMovie(movie.id);
                                    }}
                                    className="p-1 hover:bg-muted rounded"
                                  >
                                    <Heart className={`w-3 h-3 ${favoriteMovies.includes(movie.id) ? 'fill-red-500 text-red-500' : 'text-muted-foreground'}`} />
                                  </button>
                                  {movie.hd && (
                                    <Badge variant="secondary" className="text-xs">
                                      HD
                                    </Badge>
                                  )}
                                </div>
                              </div>
                              {movie.year && (
                                <p className="text-xs text-muted-foreground">{movie.year}</p>
                              )}
                              {isPlaying === movie.id.toString() && (
                                <div className="flex items-center gap-2 text-green-500">
                                  <Loader2 className="w-3 h-3 animate-spin" />
                                  <span className="text-xs">Playing...</span>
                                </div>
                              )}
                            </div>
                          </CardContent>
                        </Card>
                      </motion.div>
                    ))}
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                )}
              </div>
            </div>
          )}

          {/* ZawartoÄą>Ă"â"Ľ - Seriale */}
          {activeTab === 'series' && (
            <div className="flex-1 overflow-auto">
              <div className="p-6">
                <div className="mb-6">
                  <h1 className="text-2xl font-bold">Seriale</h1>
                  <p className="text-muted-foreground">
                    {filteredSeries.length} series available
                  </p>
                </div>

                {seriesLoading ? (
                  <div className="flex items-center justify-center h-64">
                    <Loader2 className="w-8 h-8 animate-spin" />
                    <span className="ml-2">Loading series...</span>
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                ) : filteredSeries.length === 0 ? (
                  <div className="text-center py-12">
                    <WifiOff className="w-12 h-12 mx-auto mb-4 text-muted-foreground" />
                    <h3 className="text-lg font-medium mb-2">No series found</h3>
                    <p className="text-muted-foreground">
                      Try selecting a different category or check your connection.
                    </p>
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                ) : (
                  <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-4">
                    {filteredSeries.map((seriesItem) => (
                      <motion.div
                        key={seriesItem.id}
                        whileHover={{ scale: 1.05 }}
                        whileTap={{ scale: 0.95 }}
                        className="cursor-pointer"
                        onClick={() => handleVodClick(seriesItem)}
                      >
                        <Card className="overflow-hidden hover:shadow-lg transition-shadow">
                          <div className="aspect-[2/3] bg-muted flex items-center justify-center">
                            {seriesItem.poster ? (
                              <img
                                src={seriesItem.poster}
                                alt={seriesItem.name}
                                className="w-full h-full object-cover"
                                onError={(e) => {
                                  e.currentTarget.style.display = 'none';
                                }}
                              />
                            ) : (
                              <Clapperboard className="w-12 h-12 text-muted-foreground" />
                            )}
                          </div>
                          <CardContent className="p-3">
                            <div className="space-y-2">
                              <div className="flex items-center justify-between">
                                <span className="text-sm font-medium truncate">
                                  {seriesItem.name}
                                </span>
                                <div className="flex items-center gap-1">
                                  <button
                                    onClick={(e) => {
                                      e.stopPropagation();
                                      toggleFavoriteSeries(seriesItem.id);
                                    }}
                                    className="p-1 hover:bg-muted rounded"
                                  >
                                    <Heart className={`w-3 h-3 ${favoriteSeries.includes(seriesItem.id) ? 'fill-red-500 text-red-500' : 'text-muted-foreground'}`} />
                                  </button>
                                  {seriesItem.hd && (
                                    <Badge variant="secondary" className="text-xs">
                                      HD
                                    </Badge>
                                  )}
                                </div>
                              </div>
                              {seriesItem.year && (
                                <p className="text-xs text-muted-foreground">{seriesItem.year}</p>
                              )}
                              {isPlaying === seriesItem.id.toString() && (
                                <div className="flex items-center gap-2 text-green-500">
                                  <Loader2 className="w-3 h-3 animate-spin" />
                                  <span className="text-xs">Playing...</span>
                                </div>
                              )}
                            </div>
                          </CardContent>
                        </Card>
                      </motion.div>
                    ))}
                  \n                  {/* Load More Button */}\n                  {selectedGenre !== \ *\ && hasMoreChannels && (\n                    <div className=\flex justify-center mt-6\>\n                      <Button\n                        onClick={loadMoreChannels}\n                        disabled={isLoadingMore}\n                        variant=\outline\\n                        className=\flex items-center gap-2\\n                      >\n                        {isLoadingMore ? (\n                          <>\n                            <Loader2 className=\w-4 h-4 animate-spin\ />\n                            Loading more...\n                          </>\n                        ) : (\n                          <>\n                            Load More Channels\n                            <ChevronDown className=\w-4 h-4\ />\n                          </>\n                        )}\n                      </Button>\n                    </div>\n                  )}\n                </div>
                )}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Wbudowany player */}
      {currentStream && (
        <Player
          streamUrl={currentStream.url}
          channelName={currentStream.name}
          onClose={() => setCurrentStream(null)}
        />
      )}
    </div>
  );
};
