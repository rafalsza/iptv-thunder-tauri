// =========================
// 🎬 MOVIES LIST (UI)
// =========================
import React, { useMemo, useRef, useState, useEffect, useCallback } from 'react';
import { useVirtualizer } from '@tanstack/react-virtual';
import { useMoviesInfinite, usePrefetchMovieStream } from './movies.hooks';
import { useFavorites } from '@/hooks/useFavorites';
import { usePortalsStore } from '@/store/portals.store';
import { getImageUrl } from '@/hooks/useImageCache';
import { StalkerClient } from '@/lib/stalkerAPI_new';
import { StalkerVOD, StalkerGenre } from '@/types';

interface MovieListProps {
  client: StalkerClient;
  onMovieSelect: (movie: StalkerVOD) => void;
  selectedCategory?: StalkerGenre | null;
  search: string;
}

// Global cache for image URLs to prevent flickering during virtualization remounts
const MAX_CACHE = 500;
const ROW_HEIGHT = 320;
const globalImageCache = new Map<string, string>();

function setImageCache(key: string, val: string) {
  if (globalImageCache.size >= MAX_CACHE) {
    // Remove oldest entry (Map preserves insertion order)
    globalImageCache.delete(globalImageCache.keys().next().value!);
  }
  globalImageCache.set(key, val);
}

// Memoized MovieCard component to prevent re-renders
const MovieCard = React.memo(({
  movie,
  posterUrl,
  onSelect,
  onPrefetch,
  favoriteIds,
  onToggleFavorite,
}: {
  movie: StalkerVOD;
  posterUrl: string;
  onSelect: (movie: StalkerVOD) => void;
  onPrefetch: (movie: StalkerVOD) => void;
  favoriteIds: Set<string>;
  onToggleFavorite: (e: React.MouseEvent, movie: StalkerVOD, posterUrl: string) => void;
}) => {
  // Use global cache directly - minimal state for re-render trigger
  const [_tick, setTick] = useState(0);
  const src = posterUrl ? globalImageCache.get(posterUrl) : null;
  // Initialize imageLoaded to true if already cached (prevent flicker on remount)
  const [imageLoaded, setImageLoaded] = useState(() => !!src);
  const [imageError, setImageError] = useState(false);
  const isLoading = !src;
  
  // Trigger load if not in cache
  useEffect(() => {
    if (!posterUrl || globalImageCache.has(posterUrl)) return;
    
    let mounted = true;
    getImageUrl(posterUrl).then(url => {
      setImageCache(posterUrl, url);
      if (mounted) setTick(t => t + 1);
    }).catch(() => {
      setImageCache(posterUrl, '/fallback/poster.png');
      if (mounted) setTick(t => t + 1);
    });
    return () => { mounted = false; };
  }, [posterUrl]);

  const isFavorite = favoriteIds.has(String(movie.id));

  return (
    <div
      onMouseEnter={() => onPrefetch(movie)}
      onClick={() => onSelect(movie)}
      className="cursor-pointer group h-full"
    >
      <div className="relative overflow-hidden rounded-lg border border-slate-700 hover:border-blue-500 hover:shadow-lg transition-all bg-slate-800 h-full flex flex-col">
        {/* Poster and Info - both controlled by isLoading */}
        {isLoading || imageError ? (
          <>
            {/* Poster Placeholder */}
            <div className="flex-1 bg-slate-700 relative overflow-hidden flex items-center justify-center">
              <span className="text-6xl">🎬</span>
              {/* Favorite Button */}
              <button
                onClick={(e) => onToggleFavorite(e, movie, posterUrl)}
                className="absolute top-2 right-2 text-xl bg-slate-900/50 rounded-full p-1 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-slate-900/80"
              >
                {isFavorite ? '❤️' : '🤍'}
              </button>
            </div>
            {/* Info - show when image fails to load */}
            <div className={`p-2 bg-slate-800 flex-shrink-0 min-h-[60px] ${imageError ? '' : 'invisible'}`}>
              <h3 className="font-medium text-sm text-white line-clamp-2 leading-tight mb-1">
                {movie.name}
              </h3>
              {movie.genre && (
                <span className="text-xs text-slate-500 truncate block">{movie.genre}</span>
              )}
            </div>
          </>
        ) : (
          <>
            <div className="flex-1 bg-slate-700 relative overflow-hidden">
              <img
                src={src}
                alt={movie.name}
                className="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                onLoad={() => setImageLoaded(true)}
                onError={() => setImageError(true)}
                loading="lazy"
              />
              {/* Favorite Button */}
              <button
                onClick={(e) => onToggleFavorite(e, movie, posterUrl)}
                className="absolute top-2 right-2 text-xl bg-slate-900/50 rounded-full p-1 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-slate-900/80"
              >
                {isFavorite ? '❤️' : '🤍'}
              </button>
            </div>
            {/* Info - hidden until image is actually loaded */}
            <div className={`p-2 bg-slate-800 flex-shrink-0 min-h-[60px] transition-opacity duration-200 ${imageLoaded ? 'opacity-100' : 'opacity-0'}`}>
              <h3 className="font-medium text-sm text-white line-clamp-2 leading-tight mb-1">
                {movie.name}
              </h3>
              {movie.genre && (
                <span className="text-xs text-slate-500 truncate block">{movie.genre}</span>
              )}
            </div>
          </>
        )}
      </div>
    </div>
  );
});

MovieCard.displayName = 'MovieCard';

export const MovieList: React.FC<MovieListProps> = ({ client, onMovieSelect, selectedCategory, search }) => {
  const { 
    data: movies = [], 
    isLoading, 
    error, 
    fetchNextPage, 
    hasNextPage, 
    isFetchingNextPage 
  } = useMoviesInfinite(client, selectedCategory?.id || '');
  const prefetchStream = usePrefetchMovieStream(client);
  const { getActivePortal } = usePortalsStore();
  const activePortal = getActivePortal();
  const accountId = activePortal?.id || 'default';
  const { favorites, toggleItemFavorite } = useFavorites(accountId);

  // 🔥 Fix #8: Get favorites as Set for O(1) lookup and stable reference
  const favoriteIds = useMemo(() => {
    return new Set(favorites.filter(f => f.type === 'vod').map(f => f.item_id.toString()));
  }, [favorites]);

  const [debouncedSearch, setDebouncedSearch] = useState(search);

  // Debounce search to prevent re-filtering on every keystroke
  useEffect(() => {
    const timer = setTimeout(() => {
      setDebouncedSearch(search);
    }, 200);
    return () => clearTimeout(timer);
  }, [search]);

  // 🔥 Fix #1: Only filter when search is active + hard cap
  const filtered = useMemo(() => {
    if (!debouncedSearch) return movies;

    const lower = debouncedSearch.toLowerCase();
    return movies
      .filter((m: StalkerVOD) => m.name.toLowerCase().includes(lower))
      .slice(0, 300); // hard cap for UX
  }, [movies, debouncedSearch]);

  // Track total for search cap message
  const totalSearchResults = useMemo(() => {
    if (!debouncedSearch) return 0;
    const lower = debouncedSearch.toLowerCase();
    return movies.filter((m: StalkerVOD) => m.name.toLowerCase().includes(lower)).length;
  }, [movies, debouncedSearch]);

  const parentRef = useRef<HTMLDivElement>(null);
  const [columnCount, setColumnCount] = useState(5);

  // 🔥 Fix #5: Reset scroll on category change
  useEffect(() => {
    if (parentRef.current) {
      parentRef.current.scrollTop = 0;
    }
  }, [selectedCategory?.id]);

  // Calculate columns based on container width - memoized callback
  const calculateColumns = useCallback(() => {
    if (!parentRef.current) return;
    const width = parentRef.current.offsetWidth;
    const columns = Math.max(2, Math.floor(width / 180));
    setColumnCount(columns);
  }, []);

  useEffect(() => {
    calculateColumns();
    const observer = new ResizeObserver(calculateColumns);
    if (parentRef.current) {
      observer.observe(parentRef.current);
    }
    return () => observer.disconnect();
  }, [calculateColumns]);

  const rowCount = Math.ceil(filtered.length / columnCount);

  // 🔥 Fix #6: Increase overscan to prevent white flash
  const rowVirtualizer = useVirtualizer({
    count: rowCount,
    getScrollElement: () => parentRef.current,
    estimateSize: () => ROW_HEIGHT,
    overscan: 6,
  });

  // 🔥 Fix #3: Dynamic row getter instead of pre-computed array (better for large datasets)
  const getRow = useCallback((rowIndex: number): StalkerVOD[] => {
    const start = rowIndex * columnCount;
    return filtered.slice(start, start + columnCount);
  }, [filtered, columnCount]);

  const lastScroll = useRef(0);
  const lastTime = useRef(Date.now());
  // 🔥 Fix #4: Hard guard for fetchNextPage to prevent race conditions
  const fetchingRef = useRef(false);
  // 🔥 Fix #8: Track prefetched movies to prevent DDOS
  const prefetchedRef = useRef(new Set<string>());

  // 🔥 Fix #8: Debounced prefetch with once guard + size limit
  const handlePrefetch = useCallback((movie: StalkerVOD) => {
    const movieId = String(movie.id);
    if (prefetchedRef.current.has(movieId)) return;
    
    // Prevent infinite growth - clear when too large
    if (prefetchedRef.current.size > 2000) {
      prefetchedRef.current.clear();
    }
    
    prefetchedRef.current.add(movieId);
    prefetchStream(movie);
  }, [prefetchStream, hasNextPage]);

  const handleToggleFavorite = useCallback((e: React.MouseEvent, movie: StalkerVOD, posterUrl: string) => {
    e.stopPropagation();
    toggleItemFavorite('vod', movie.id, {
      name: movie.name,
      poster: posterUrl,
      cmd: movie.cmd,
    });
  }, [toggleItemFavorite]);

  const handleScroll = useCallback((e: React.UIEvent<HTMLDivElement>) => {
    const el = e.currentTarget;

    const now = Date.now();
    // 🔥 Fix #4: Smooth velocity with tighter clamp

    lastScroll.current = el.scrollTop;
    lastTime.current = now;

    // 🔥 Fix #7: Pixel-based nearBottom instead of percentage
    const nearBottom = el.scrollHeight - (el.scrollTop + el.clientHeight) < 500;

    // 🔥 Fix #4: Hard guard for fetchNextPage
    if (nearBottom && hasNextPage && !isFetchingNextPage && !fetchingRef.current) {
      fetchingRef.current = true;
      fetchNextPage().finally(() => {
        fetchingRef.current = false;
      });
    }
  }, [fetchNextPage, hasNextPage, isFetchingNextPage]);

  if (isLoading) {
    return (
      <div className="flex-1 flex items-center justify-center">
        <div className="text-lg text-white">Loading movies...</div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="flex-1 flex items-center justify-center">
        <div className="text-lg text-red-500">Error loading movies</div>
      </div>
    );
  }

  return (
    <div className="flex-1 flex flex-col overflow-hidden bg-slate-900">
      {/* Category Header */}
      {selectedCategory && (
        <div className="bg-slate-800 border-b border-slate-700 p-4">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center text-xl">
              🎬
            </div>
            <div>
              <h2 className="text-lg font-bold text-white">{selectedCategory.title}</h2>
              <p className="text-sm text-slate-400">
                {debouncedSearch && totalSearchResults > 300 
                  ? `Showing 300 of ${totalSearchResults} results` 
                  : `${filtered.length} filmów`}
              </p>
            </div>
          </div>
        </div>
      )}

      {/* Virtualized Movies Grid */}
      <div ref={parentRef} onScroll={handleScroll} className="flex-1 overflow-y-auto p-4">
        <div
          style={{
            height: `${rowVirtualizer.getTotalSize()}px`,
            width: '100%',
            position: 'relative',
          }}
        >
          {rowVirtualizer.getVirtualItems().map((virtualRow) => {
            const rowIndex = virtualRow.index;
            // 🔥 Fix #3: Dynamic row getter
            const rowMovies = getRow(rowIndex);

            return (
              <div
                key={virtualRow.key}
                style={{
                  position: 'absolute',
                  top: 0,
                  left: 0,
                  width: '100%',
                  height: `${ROW_HEIGHT}px`,
                  transform: `translateY(${virtualRow.start}px)`,
                }}
              >
                <div
                  className="grid gap-4 h-full"
                  style={{
                    gridTemplateColumns: `repeat(${columnCount}, 1fr)`,
                  }}
                >
                  {rowMovies.map((movie) => {
                    const posterUrl = movie.poster || movie.logo || '';
                    return (
                      <MovieCard
                        key={String(movie.id)}
                        movie={movie}
                        posterUrl={posterUrl}
                        onSelect={onMovieSelect}
                        onPrefetch={handlePrefetch}
                        favoriteIds={favoriteIds}
                        onToggleFavorite={handleToggleFavorite}
                      />
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>

        {/* Loading indicator */}
        {isFetchingNextPage && (
          <div className="flex justify-center py-4">
            <div className="bg-slate-800 px-4 py-2 rounded-full text-white text-sm">
              Loading more...
            </div>
          </div>
        )}
      </div>
    </div>
  );
};
